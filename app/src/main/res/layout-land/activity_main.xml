<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    tools:context=".MainActivity">

    <!-- ════ GUIDELINES ════ -->

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCol1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.26" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineCol2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.70" />

    <!-- ════ HEADER ════ -->

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:contentDescription="@string/app_name"
        android:src="@android:drawable/ic_menu_compass"
        app:tint="#1565C0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:text="@string/app_name"
        android:textColor="#1565C0"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/ivLogo"
        app:layout_constraintEnd_toStartOf="@id/guidelineCol1"
        app:layout_constraintTop_toTopOf="@id/ivLogo"
        app:layout_constraintBottom_toBottomOf="@id/ivLogo" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardElement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#E0E0E0"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvElement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:text="@string/app_name"
            android:textColor="#424242"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            tools:text="Element 3 / 10" />
    </com.google.android.material.card.MaterialCardView>

    <!-- ════ LEFT — Score Circle ════ -->

    <View
        android:id="@+id/scoreCircle"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/circle_border_blue"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineCol1"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#1565C0"
        android:textSize="52sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/scoreCircle"
        app:layout_constraintBottom_toBottomOf="@id/scoreCircle"
        app:layout_constraintStart_toStartOf="@id/scoreCircle"
        app:layout_constraintEnd_toEndOf="@id/scoreCircle"
        tools:text="6" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDeductionBadge"
        android:layout_width="60dp"
        android:layout_height="26dp"
        android:visibility="gone"
        app:cardBackgroundColor="#C62828"
        app:cardCornerRadius="13dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/scoreCircle"
        app:layout_constraintStart_toStartOf="@id/scoreCircle"
        app:layout_constraintEnd_toEndOf="@id/scoreCircle"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/deduction_badge"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMaxPts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/max_points"
        android:textColor="#757575"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/scoreCircle"
        app:layout_constraintStart_toStartOf="@id/scoreCircle"
        app:layout_constraintEnd_toEndOf="@id/scoreCircle" />

    <!-- ════ CENTER — Difficulty + Complete ════ -->

    <TextView
        android:id="@+id/textView4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:letterSpacing="0.12"
        android:text="@string/difficulty_label"
        android:textColor="#424242"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/guidelineCol1"
        app:layout_constraintEnd_toStartOf="@id/guidelineCol2"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/difficultySelector"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_rounded_border"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintStart_toStartOf="@id/guidelineCol1"
        app:layout_constraintEnd_toStartOf="@id/guidelineCol2"
        app:layout_constraintTop_toBottomOf="@id/textView4">

        <TextView
            android:id="@+id/tvZoneEasy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_pill_blue"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/zone_basic"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvZoneIntermediate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/zone_intermediate"
            android:textColor="#616161"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvZoneAdvance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/zone_advanced"
            android:textColor="#616161"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tvComplete"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/guidelineCol1"
        app:layout_constraintEnd_toStartOf="@id/guidelineCol2"
        app:layout_constraintTop_toBottomOf="@id/difficultySelector"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/routine_complete"
            android:src="@android:drawable/star_big_on"
            app:tint="#1565C0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/routine_complete"
            android:textColor="#1565C0"
            android:textSize="18sp"
            android:textStyle="bold|italic" />
    </LinearLayout>

    <!-- ════ RIGHT — Buttons ════ -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPerform"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="10dp"
        android:backgroundTint="#1565C0"
        android:text="@string/btn_perform"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        app:cornerRadius="10dp"
        app:icon="@android:drawable/ic_media_play"
        app:iconGravity="textStart"
        app:iconTint="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btnDeduction"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guidelineCol2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeduction"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FFEBEE"
        android:text="@string/btn_deduction"
        android:textColor="#D32F2F"
        android:textSize="11sp"
        android:textStyle="bold"
        app:cornerRadius="10dp"
        app:strokeColor="#FFCDD2"
        app:strokeWidth="1dp"
        app:layout_constraintStart_toStartOf="@id/guidelineCol2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnPerform"
        app:layout_constraintBottom_toTopOf="@id/btnReset" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReset"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:text="@string/btn_reset"
        android:textColor="#616161"
        android:textSize="13sp"
        app:cornerRadius="10dp"
        app:icon="@android:drawable/ic_menu_rotate"
        app:iconGravity="textStart"
        app:iconTint="#5F5F5E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/guidelineCol2"
        app:layout_constraintTop_toBottomOf="@id/btnDeduction"
        app:strokeColor="#BDBDBD" />

</androidx.constraintlayout.widget.ConstraintLayout>